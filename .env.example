# institute-one configuration (all optional — sane defaults built in)
# Copy to .env and edit. Env vars use the INSTITUTE_ prefix.

# Where everything lives (db, workspaces, archive, logs)
#INSTITUTE_HOME=~/.institute-one

#INSTITUTE_HOST=127.0.0.1
#INSTITUTE_PORT=8100

# Obsidian vault export — point at the subtree the institute OWNS.
# Leave unset to disable the vault layer.
#INSTITUTE_VAULT_DIR=/Users/you/Obsidian/Main/Institute

# Execution
#INSTITUTE_MAX_CONCURRENT=3
#INSTITUTE_DEFAULT_HAND=claude
#INSTITUTE_DEFAULT_TIMEOUT_S=1800

# Hand enables (CLI hands also require the binary on your login-shell PATH)
#INSTITUTE_ENABLE_CLAUDE=true
#INSTITUTE_ENABLE_CODEX=true
#INSTITUTE_ENABLE_GEMINI=true
#INSTITUTE_ENABLE_AGY=true
#INSTITUTE_ENABLE_OPENCODE=true
#INSTITUTE_ENABLE_OLLAMA=false

# Per-hand default models (blank -> the CLI's own default)
#INSTITUTE_CLAUDE_MODEL=
#INSTITUTE_CODEX_MODEL=
#INSTITUTE_GEMINI_MODEL=
#INSTITUTE_OPENCODE_MODEL=
#INSTITUTE_OLLAMA_MODEL=llama3.2
#INSTITUTE_OLLAMA_HOST=http://localhost:11434

# Direct-API fallback hands (registered only when a key is present)
#INSTITUTE_ANTHROPIC_API_KEY=
#INSTITUTE_OPENAI_API_KEY=
#INSTITUTE_GOOGLE_API_KEY=

# Schedule (SGT). Empty string disables a job.
#INSTITUTE_BRIEFING_TIME=08:30
#INSTITUTE_DAILY_TIME=23:00
#INSTITUTE_ANALYST_DAILY_TIME=19:00
#INSTITUTE_SCORECARD_TIME=00:05
#INSTITUTE_WHITEBOARD_KICKOFF_MINUTES=60
#INSTITUTE_RESEARCH_TICK_MINUTES=30
#INSTITUTE_RESEARCH_DAILY_CAP=4
#INSTITUTE_RESEARCH_COOLDOWN_DAYS=30
