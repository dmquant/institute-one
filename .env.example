# institute-one configuration (all optional — sane defaults built in)
# Copy to .env and edit. Env vars use the INSTITUTE_ prefix.

# Where everything lives (db, workspaces, archive, logs, backups)
#INSTITUTE_HOME=~/.institute-one

#INSTITUTE_HOST=127.0.0.1
#INSTITUTE_PORT=8100

# Scheduler timezone (also drives "work date" logic); must be a valid IANA
# zone — invalid values fail at config load.
#INSTITUTE_TIMEZONE=Asia/Singapore

# Optional bearer auth. Unset/empty = auth disabled (localhost-only default).
#INSTITUTE_TOKEN=

# Obsidian vault export — point at the subtree the institute OWNS.
# Leave unset to disable the vault layer.
#INSTITUTE_VAULT_DIR=/Users/you/Obsidian/Main/Institute

# Execution
# >=1. Do NOT set 0 to pause work (it would silently starve every task) —
# use POST /api/admin/maintenance for that.
#INSTITUTE_MAX_CONCURRENT=3
# Per-hand queued-depth cap; a submit beyond this fast-fails as 'overcommitted'.
# <=0 disables the check.
#INSTITUTE_HAND_QUEUE_DEPTH=8
#INSTITUTE_DEFAULT_HAND=claude
# Comma-separated hands the deep-research workflow round-robins over
#INSTITUTE_RESEARCH_HANDS=codex,agy
# >0 (seconds); 0/negative would expire every task instantly
#INSTITUTE_DEFAULT_TIMEOUT_S=1800
# tasks.output column cap (bytes); larger deliverables live as workspace files.
# >0 — 0 would silently blank all task output.
#INSTITUTE_OUTPUT_CAP_BYTES=200000

# Hand enables (CLI hands also require the binary on your login-shell PATH)
#INSTITUTE_ENABLE_CLAUDE=true
#INSTITUTE_ENABLE_CODEX=true
#INSTITUTE_ENABLE_GEMINI=true
#INSTITUTE_ENABLE_AGY=true
#INSTITUTE_ENABLE_OPENCODE=true
#INSTITUTE_ENABLE_OLLAMA=false
# Trivial built-in hand used by tests/smoke checks
#INSTITUTE_ENABLE_ECHO=true

# Weighted hand selection (hand_weights table). Opt-in: false keeps the
# pre-weights selection behaviour unchanged.
#INSTITUTE_ENABLE_HAND_WEIGHTS=false

# Per-hand default models (blank -> the CLI's own default)
#INSTITUTE_CLAUDE_MODEL=
#INSTITUTE_CODEX_MODEL=
#INSTITUTE_GEMINI_MODEL=
#INSTITUTE_OPENCODE_MODEL=
#INSTITUTE_OLLAMA_MODEL=llama3.2
#INSTITUTE_OLLAMA_HOST=http://localhost:11434

# Vector search (needs Ollama + sqlite-vec; off = documented FTS5-only path)
#INSTITUTE_ENABLE_VECTORS=false
#INSTITUTE_EMBED_MODEL=bge-m3

# Direct-API fallback hands (registered only when a key is present)
#INSTITUTE_ANTHROPIC_API_KEY=
#INSTITUTE_OPENAI_API_KEY=
#INSTITUTE_GOOGLE_API_KEY=
#INSTITUTE_ANTHROPIC_API_MODEL=claude-sonnet-4-6
#INSTITUTE_OPENAI_API_MODEL=gpt-5.2
#INSTITUTE_GOOGLE_API_MODEL=gemini-2.5-pro
# Base URLs — override to point a hand at an API-compatible local gateway
# (e.g. CLIProxyAPI / litellm) instead of the official endpoint.
#INSTITUTE_ANTHROPIC_API_BASE_URL=https://api.anthropic.com
#INSTITUTE_OPENAI_API_BASE_URL=https://api.openai.com/v1
#INSTITUTE_GOOGLE_API_BASE_URL=https://generativelanguage.googleapis.com

# Market data fetchers (ladder: FMP -> Stooq -> Sina; Stooq/Sina are keyless)
#INSTITUTE_FMP_API_KEY=
# Outbound HTTP(S) proxy for fetchers, e.g. http://127.0.0.1:7897 (mihomo)
#INSTITUTE_FETCH_PROXY=
# Kill switch for the hourly market-refresh job
#INSTITUTE_MARKET_FETCH_ENABLED=true
# Refresh cadence in minutes; 0/negative disables
#INSTITUTE_MARKET_REFRESH_MINUTES=60
# Securities per sweep (stalest first)
#INSTITUTE_MARKET_REFRESH_LIMIT=20

# Schedule (SGT). Empty string disables a time-of-day job.
#INSTITUTE_BRIEFING_TIME=08:30
#INSTITUTE_DAILY_TIME=23:00
#INSTITUTE_ANALYST_DAILY_TIME=19:00
# Previous-day hand quality settlement
#INSTITUTE_SCORECARD_TIME=00:05
# Analyst standing-memory nightly compact
#INSTITUTE_MEMORY_COMPACT_TIME=23:30
# Weekly committee (fires Fridays only)
#INSTITUTE_COMMITTEE_TIME=20:00
#INSTITUTE_WHITEBOARD_KICKOFF_MINUTES=60
# Advance running whiteboards every N seconds
#INSTITUTE_WHITEBOARD_TICK_SECONDS=60
#INSTITUTE_MAILBOX_SWEEP_SECONDS=120
#INSTITUTE_RESEARCH_TICK_MINUTES=30
# Completed runs per SGT work date; 0/negative disables the research queue
#INSTITUTE_RESEARCH_DAILY_CAP=4
#INSTITUTE_RESEARCH_COOLDOWN_DAYS=30
# Janitor sweep cadence (minutes)
#INSTITUTE_JANITOR_MINUTES=60
# Durable SSE/audit event replay window (days)
#INSTITUTE_EVENTS_RETENTION_DAYS=90

# Fact-check (Phase 3)
# Tick cadence in minutes; 0/negative disables the job
#INSTITUTE_FACTCHECK_TICK_MINUTES=30
# Verification attempts per SGT work date (unset -> module default, 10)
#INSTITUTE_FACTCHECK_DAILY_CAP=
